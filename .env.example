# Copy to .env if you want to override local Docker defaults.
RITRIEVER_MARIADB_VERSION=11.8
RITRIEVER_MYSQL_VERSION=9.4

RITRIEVER_WP_MARIADB_PORT=8081
RITRIEVER_WP_MYSQL_PORT=8082
RITRIEVER_MARIADB_PORT=33071
RITRIEVER_MYSQL_PORT=33072
RITRIEVER_EMBEDDING_PORT=18080

# Keep local smoke-test vectors small. The setup script writes this value
# to the plugin setting before activation so the vector table matches it.
RITRIEVER_EMBEDDING_DIMENSIONS=16

# Used by scripts/docker-setup-stack.sh for WordPress siteurl/home.
RITRIEVER_HOST=192.168.1.35
